<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brand gradient: indigo to violet, diagonal so the icon reads well at any size. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="94"
                android:endY="104"
                android:startX="14"
                android:startY="4"
                android:type="linear">
                <item
                    android:color="#FF7C6CFF"
                    android:offset="0.0" />
                <item
                    android:color="#FF5A4BE8"
                    android:offset="0.45" />
                <item
                    android:color="#FF2E2A9E"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft highlight behind the mark so the shield lifts off the background. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="32"
                android:gradientRadius="62"
                android:type="radial">
                <item
                    android:color="#33FFFFFF"
                    android:offset="0.0" />
                <item
                    android:color="#00FFFFFF"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
